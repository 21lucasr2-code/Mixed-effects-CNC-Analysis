    "library(lme4)\n",
    "\n",
    "# Fit mixed-effects model\n",
    "model <- lmer(Ra ~ ap * vc * f + (1 | Run), data = data)\n",
    "\n",
    "# ANOVA table\n",
    "anova(model)"
   ]
