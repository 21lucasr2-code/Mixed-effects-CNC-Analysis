    "# Load libraries silently\n",
    "suppressPackageStartupMessages({\n",
    "  library(nlme)\n",
    "  library(modelsummary)\n",
    "  library(kableExtra)\n",
    "})\n",
    "\n",
    "# Keep original data untouched\n",
    "data_diag <- data.frame(data)\n",
    "\n",
    "# Fit model\n",
    "mixed_model <- lme(\n",
    "  Ra ~ ap * vc * f,\n",
    "  random = ~1 | Run,\n",
    "  data = data_diag\n",
    ")\n",
    "\n",
    "# Extract normalized residuals\n",
    "data_diag$res_abs <- abs(resid(mixed_model, type = \"normalized\"))\n",
    "\n",
    "# Ensure feed rate is numeric (for regression trend test)\n",
    "data_diag$f_num <- as.numeric(as.character(data_diag$f))\n",
    "\n",
    "# Individual variance checks\n",
    "lm_ap <- lm(res_abs ~ ap, data = data_diag)\n",
    "lm_vc <- lm(res_abs ~ vc, data = data_diag)\n",
    "lm_f  <- lm(res_abs ~ f_num, data = data_diag)\n",
    "\n",
    "# Combined variance model\n",
    "lm_all <- lm(res_abs ~ ap + vc + f_num, data = data_diag)\n",
    "\n",
    "# Generate the table with escape=FALSE\n",
    "ms_table <- modelsummary(\n",
    "  list(\n",
    "    \"Ap_Effect\" = lm_ap,\n",
    "    \"Vc_Effect\" = lm_vc,\n",
    "    \"Feed_Rate\" = lm_f,\n",
    "    \"Combined\"  = lm_all\n",
    "  ),\n",
    "  statistic = \"({std.error})\",\n",
    "  stars = TRUE,\n",
    "  output = \"kableExtra\",\n",
    "  escape = TRUE # Prevents double-escaping of HTML characters\n",
    ") %>%\n",
    "  kable_styling(bootstrap_options = c(\"striped\", \"hover\"))\n",
    "\n",
    "# HTML conversion\n",
    "clean_html <- as.character(ms_table)\n",
    "\n",
    "# Display\n",
    "IRdisplay::display_html(clean_html)"
   ]
