    "library(ggplot2)\n",
    "library(patchwork)\n",
    "\n",
    "theme_set(theme_minimal())\n",
    "\n",
    "p1 <- ggplot(data, aes(x = ap, y = Ra)) +\n",
    "  geom_boxplot(fill = \"skyblue\") +\n",
    "  labs(title = \"ap vs Ra\", x = \"ap\", y = \"Ra\")\n",
    "\n",
    "p2 <- ggplot(data, aes(x = vc, y = Ra)) +\n",
    "  geom_boxplot(fill = \"lightgreen\") +\n",
    "  labs(title = \"vc vs Ra\", x = \"vc\", y = \"Ra\")\n",
    "\n",
    "p3 <- ggplot(data, aes(x = f, y = Ra)) +\n",
    "  geom_boxplot(fill = \"salmon\") +\n",
    "  labs(title = \"f vs Ra\", x = \"f\", y = \"Ra\")\n",
    "\n",
    "(p1 | p2 | p3) +\n",
    "  plot_layout(widths = c(1, 1, 1))"
   ]
