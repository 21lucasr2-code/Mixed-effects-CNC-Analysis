    "library(dplyr)\n",
    "\n",
    "# Load data\n",
    "data <- read.csv(\"/kaggle/input/datasets/adorigueto/cnc-turning-roughness-forces-and-tool-wear/Exp1.csv\")\n",
    "\n",
    "# Convert to factors\n",
    "data <- data %>%\n",
    "  mutate(across(c(ap, vc, f, Replica, Position), as.factor))\n",
    "\n",
    "# Keep relevant variables\n",
    "data <- data %>%\n",
    "  select(ap, vc, f, Ra, Replica, Position)\n",
    "\n",
    "# Create Run ID \n",
    "data$Run <- interaction(data$ap, data$vc, data$f, data$Replica)"
   ]
