    "library(nlme)\n",
    "\n",
    "data$f_num <- as.numeric(as.character(data$f)) # create numeric feed rate\n",
    "\n",
    "final_model <- lme(\n",
    "  Ra ~ ap * vc * f,              # mean structure (fixed effects)\n",
    "  random = ~1 | Run,             # random run-to-run variation\n",
    "  weights = varPower(form = ~ f_num), # variance increases with feed rate\n",
    "  data = data,\n",
    "  method = \"REML\"\n",
    ")\n",
    "\n",
    "anova(final_model)"
   ]
